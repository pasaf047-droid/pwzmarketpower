<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PWZMarketPower</title>

<style>

body{
font-family:Arial;
background:#f4f4f4;
text-align:center;
padding:50px;
}

.box{
background:white;
padding:30px;
max-width:400px;
margin:auto;
border-radius:10px;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

input{
width:90%;
padding:10px;
margin:10px 0;
border:1px solid #ccc;
border-radius:5px;
}

button{
padding:10px 20px;
background:#2962ff;
color:white;
border:none;
border-radius:5px;
cursor:pointer;
}

#download{
display:none;
margin-top:20px;
}

</style>

</head>

<body>

<div class="box">

<h2>Área de Download</h2>

<p>Digite a KEY recebida por email</p>

<input type="password" id="key" placeholder="Digite a KEY">

<br>

<button onclick="verificar()">Liberar PDF</button>

<div id="download">

<p>Download liberado</p>

<a href="marketing2026.pdf" download>
<button>Baixar PDF</button>
</a>

</div>

</div>

<script>

function verificar(){

var keyDigitada = document.getElementById("key").value;

if(keyDigitada === "pwz2013"){

document.getElementById("download").style.display = "block";

}else{

alert("KEY inválida");

}

}

</script>

</body>
</html>
